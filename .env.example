# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: required for host YouTube playlists (OAuth token storage). Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# YouTube Data API v3 key (Google Cloud Console). Used only on the server by /api/youtube/search.
YOUTUBE_API_KEY=your_youtube_api_key

# Google OAuth (Web client) — same Cloud project as YouTube API. Used for host playlist import.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud exactly, e.g. http://localhost:3000/api/youtube/oauth/callback
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/youtube/oauth/callback

# Random secret (16+ chars) to sign OAuth state cookies — use openssl rand -hex 32
YOUTUBE_OAUTH_STATE_SECRET=

# Vertex AI (Gemini) — used by /api/recommendations/* (server only).
# Auth uses IAM (service account / workload identity). No API key is required.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# Optional but strongly recommended for local `gcloud auth application-default login` (user ADC).
# This becomes the x-goog-user-project header used for quota/billing on publisher models.
GOOGLE_CLOUD_QUOTA_PROJECT=your_gcp_project_id
VERTEX_LOCATION=us-central1
# Vertex model id (must be a model your project has access to).
# Common: gemini-2.0-flash-001 (default) or gemini-2.0-flash-lite(-001) if enabled.
VERTEX_GEMINI_MODEL=gemini-2.0-flash-001
