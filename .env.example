# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: required for host YouTube playlists (OAuth token storage). Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# YouTube Data API v3 key(s) (Google Cloud Console). Used only on the server by /api/youtube/search.
# Optional: provide multiple keys for automatic failover on quota/rate-limit errors.
# Comma or newline separated.
YOUTUBE_API_KEY=your_youtube_api_key
# YOUTUBE_API_KEYS=key1,key2,key3

# Google OAuth (Web client) — same Cloud project as YouTube API. Used for host playlist import.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud exactly, e.g. http://localhost:3000/api/youtube/oauth/callback
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/youtube/oauth/callback

# Random secret (16+ chars) to sign OAuth state cookies — use openssl rand -hex 32
YOUTUBE_OAUTH_STATE_SECRET=

# Vertex AI (Gemini) — used by /api/recommendations/* (server only).
# Local: `gcloud auth application-default login` (user ADC). No API key.
# Vercel: create a service account with "Vertex AI User", download JSON key, paste the
# entire JSON as one line into GOOGLE_APPLICATION_CREDENTIALS_JSON (mark Encrypted).
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# x-goog-user-project for quota/billing (local ADC + Vercel). Often same as GOOGLE_CLOUD_PROJECT.
GOOGLE_CLOUD_QUOTA_PROJECT=your_gcp_project_id
# Vercel/production only — full service account key JSON (single line). Do not commit.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
VERTEX_LOCATION=us-central1
# Vertex model id (must be a model your project has access to).
# Common: gemini-2.0-flash-001 (default) or gemini-2.0-flash-lite(-001) if enabled.
VERTEX_GEMINI_MODEL=gemini-2.0-flash-001

# Vertex AI Vector Search (Personalization / RAG)
# Create an Index + IndexEndpoint, deploy the index, then fill these in.
# Note: querying a public endpoint uses a domain like `xxxx.<location>-<projectNumber>.vdb.vertexai.goog`.
VERTEX_VECTOR_LOCATION=us-central1
VERTEX_VECTOR_INDEX_ID=
VERTEX_VECTOR_INDEX_ENDPOINT_ID=
VERTEX_VECTOR_DEPLOYED_INDEX_ID=
# Public endpoint domain (no protocol), e.g. `1957880287.us-central1-181224308459.vdb.vertexai.goog`
VERTEX_VECTOR_PUBLIC_ENDPOINT_DOMAIN=
# Embeddings model for taste docs and queries.
VERTEX_EMBEDDINGS_MODEL=text-embedding-004
